{
    "name": "meulah/framework",
    "description": "A small, explicit PHP framework for conventional server-rendered applications.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "php",
        "framework",
        "mvc",
        "routing",
        "server-rendered"
    ],
    "homepage": "https://github.com/Meulah/framework",
    "support": {
        "issues": "https://github.com/Meulah/framework/issues",
        "source": "https://github.com/Meulah/framework",
        "security": "https://github.com/Meulah/framework/security/policy"
    },
    "require": {
        "php": "^8.1",
        "ext-fileinfo": "*",
        "ext-pdo": "*",
        "composer-runtime-api": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "Meulah\\": "src/"
        }
    },
    "bin": [
        "bin/meulah"
    ],
    "suggest": {
        "ext-pdo_mysql": "Required when using the MySQL database driver.",
        "ext-pdo_pgsql": "Required when using the PostgreSQL database driver.",
        "ext-pdo_sqlite": "Required when using the SQLite database driver."
    },
    "scripts": {
        "test": "php tests/run.php",
        "check": [
            "@lint",
            "@test"
        ]
    },
    "config": {
        "sort-packages": true
    }
}
