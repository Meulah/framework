APP_ENV=development
HTTP_MAX_BODY_SIZE=10485760

# Database driver - choose one:
# DB_DRIVER=mysql
# DB_DRIVER=pgsql
# DB_DRIVER=sqlite
DB_DRIVER=mysql

# MySQL / PostgreSQL
DB_HOST=127.0.0.1
DB_PORT=
DB_NAME=meulah
DB_USER=root
DB_PASS=

# SQLite only; relative paths resolve from the project root.
# Use :memory: for an in-memory database.
DB_PATH=database.sqlite



DB_MIGRATIONS=database/migrations
DB_MIGRATION_TABLE=meulah_migrations
