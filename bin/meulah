#!/usr/bin/env php
<?php

declare(strict_types=1);

use Meulah\Console\Launcher;

$packageRoot = dirname(__DIR__);
$autoloaders = [
    $packageRoot . '/vendor/autoload.php',
    dirname($packageRoot, 2) . '/autoload.php',
];

foreach ($autoloaders as $autoload) {
    if (is_file($autoload)) {
        require_once $autoload;
        break;
    }
}

if (!class_exists(Launcher::class)) {
    fwrite(STDERR, 'Composer dependencies are missing. Run composer install.' . PHP_EOL);
    exit(1);
}

exit((new Launcher())->run($argv));
